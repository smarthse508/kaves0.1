{
	"name": "open3dfloorplan",
	"private": true,
	"version": "0.9.0",
	"description": "Free open source 2D/3D floor plan editor — design in 2D, preview in 3D, all in your browser",
	"author": "theLodgeStudio",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/theLodgeBots/open3dFloorplan.git"
	},
	"type": "module",
	"scripts": {
		"dev": "vite --port 5000",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-node": "^5.5.3",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/three": "^0.182.0",
		"firebase": "^12.9.0",
		"svelte": "^5.55.1",
		"svelte-check": "^4.3.6",
		"tailwindcss": "^4.1.18",
		"three": "^0.182.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"dxf-writer": "^1.18.4",
		"jspdf": "^4.1.0",
		"jszip": "^3.10.1"
	}
}
